# ─── Google Cloud ───────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=US
GOOGLE_CLOUD_REGION=us-central1

# ─── Google Maps Platform ──────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Requires: Maps JavaScript API, Places API (New), Routes API enabled

# ─── Weather ────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
# Free tier: https://openweathermap.org/api

# ─── Aviation (optional) ────────────────────────────────
AVIATIONSTACK_API_KEY=your-aviationstack-api-key
# Free tier: https://aviationstack.com/signup/free

# ─── BigQuery ───────────────────────────────────────────
BQ_SOURCE_DATASET=bigquery-public-data.thelook_ecommerce

# ─── Agent Models ──────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
PLANNER_MODEL=gemini-2.5-flash

# ─── MCP Toolbox ────────────────────────────────────────
USE_MCP_TOOLBOX=true
MCP_TOOLBOX_URI=http://127.0.0.1:5000

# ─── Guardrails ─────────────────────────────────────────
MAX_BYTES_PROCESSED=2147483648
MAX_RECURSION_LIMIT=30
